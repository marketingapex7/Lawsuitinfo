---
import { getCollection, render } from "astro:content";
import GuideLayout from "@layouts/GuideLayout.astro";
import CaseStatusBadge from "@components/CaseStatusBadge.astro";
import CaseStatusSnapshot from "@components/CaseStatusSnapshot.astro";
import QuickFactsCard from "@components/QuickFactsCard.astro";
import TableOfContents from "@components/TableOfContents.astro";
import FAQSection from "@components/FAQSection.astro";
import RelatedLawsuits from "@components/RelatedLawsuits.astro";
import RelatedStateGuides from "@components/RelatedStateGuides.astro";
import SourceUpdateLog from "@components/SourceUpdateLog.astro";
import DisclaimerBox from "@components/DisclaimerBox.astro";
import LitigationDataPanel from "@components/LitigationDataPanel.astro";
import { entrySlug } from "@lib/content";
import { getCaseData } from "@lib/caseData";
import { formatDate } from "@lib/site";
import { lawsuitMetaDescription, lawsuitSeoTitle } from "@lib/seo";

export async function getStaticPaths() {
  const lawsuits = await getCollection("lawsuits");
  return lawsuits.map((lawsuit) => ({
    params: { slug: entrySlug(lawsuit) },
    props: { lawsuit }
  }));
}

const { lawsuit } = Astro.props;
const slug = entrySlug(lawsuit);
const caseData = getCaseData(slug);
const { Content } = await render(lawsuit);
const stateGuides = (await getCollection("state-guides"))
  .filter((guide) => guide.data.lawsuitSlug === slug)
  .sort((a, b) => a.data.state.localeCompare(b.data.state));
const related = (await getCollection("lawsuits"))
  .filter((item) => entrySlug(item) !== slug)
  .sort((a, b) => Number(b.data.category === lawsuit.data.category) - Number(a.data.category === lawsuit.data.category))
  .slice(0, 4);
const seoTitle = lawsuitSeoTitle(lawsuit.data.lawsuit);
const seoDescription = lawsuitMetaDescription(lawsuit.data.lawsuit, lawsuit.data.primaryInjury);
const relatedTitle = lawsuit.data.category === "Toxic Exposure" ? "Related Toxic Exposure Guides" : "Related Lawsuits";
const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Lawsuits", url: "/lawsuits/" },
  { name: lawsuit.data.lawsuit, url: `/lawsuits/${slug}/` }
];
const toc = [
  { id: "overview", label: "What the lawsuit is about" },
  { id: "latest-update", label: "Latest update" },
  { id: "case-status-snapshot", label: "Case snapshot" },
  { id: "litigation-updates", label: "Litigation updates" },
  { id: "status", label: "Current status" },
  { id: "eligibility", label: "Who may be affected" },
  { id: "injuries", label: "Injuries involved" },
  { id: "evidence", label: "Evidence usually needed" },
  { id: "settlement", label: "Settlement status" },
  { id: "sources-status-notes", label: "Sources and notes" },
  { id: "states", label: "State guides" },
  { id: "faq", label: "FAQ" }
];

if (slug === "roundup") {
  toc.splice(3, 0, { id: "roundup-eligibility", label: "Who qualifies" });
  toc.splice(6, 0, { id: "when-roundup-lawsuit-started", label: "When it started" });
  toc.splice(12, 0, { id: "roundup-statute-limitations", label: "Statute of limitations" });
}

if (slug === "paraquat") {
  toc.splice(3, 0, { id: "paraquat-parkinsons-lawsuit", label: "Parkinson's lawsuit" });
  toc.splice(4, 0, { id: "paraquat-qualifications", label: "Qualifications" });
  toc.splice(7, 0, { id: "paraquat-settlement-status", label: "Settlement status" });
  toc.splice(12, 0, { id: "paraquat-herbicide-exposure", label: "Exposure examples" });
  toc.splice(15, 0, { id: "paraquat-deadlines", label: "Deadline considerations" });
}

if (slug === "afff-pfas") {
  toc.splice(3, 0, { id: "afff-lawsuit-overview", label: "AFFF lawsuit" });
  toc.splice(4, 0, { id: "afff-qualifications", label: "Who may qualify" });
  toc.splice(7, 0, { id: "afff-settlement-status", label: "Settlement status" });
  toc.splice(12, 0, { id: "afff-exposure-pathways", label: "Exposure pathways" });
  toc.splice(13, 0, { id: "afff-records", label: "Records reviewed" });
  toc.splice(16, 0, { id: "afff-deadlines", label: "Deadline considerations" });
}

if (slug === "ozempic") {
  toc.splice(3, 0, { id: "ozempic-drugs-included", label: "Drugs included" });
  toc.splice(4, 0, { id: "ozempic-qualifications", label: "Who may qualify" });
  toc.splice(7, 0, { id: "ozempic-bellwether-trials", label: "Path to first trials" });
  toc.splice(13, 0, { id: "ozempic-injury-details", label: "Injuries alleged" });
  toc.splice(16, 0, { id: "ozempic-deadlines", label: "Deadline considerations" });
}

if (slug === "camp-lejeune") {
  toc.splice(3, 0, { id: "camp-lejeune-deadline", label: "Filing deadline status" });
  toc.splice(4, 0, { id: "camp-lejeune-elective-option", label: "Elective Option payouts" });
  toc.splice(7, 0, { id: "camp-lejeune-qualifications", label: "Who qualified" });
  toc.splice(13, 0, { id: "camp-lejeune-conditions", label: "Covered conditions" });
  toc.splice(16, 0, { id: "camp-lejeune-pending-claims", label: "Pending claims" });
}

if (slug === "suboxone") {
  toc.splice(3, 0, { id: "suboxone-dental-lawsuit", label: "Dental lawsuit" });
  toc.splice(4, 0, { id: "suboxone-eligibility", label: "Eligibility" });
  toc.splice(7, 0, { id: "suboxone-settlement-status", label: "Settlement status" });
  toc.splice(12, 0, { id: "suboxone-dental-records", label: "Dental records" });
  toc.splice(13, 0, { id: "suboxone-timing", label: "Use and injury timing" });
  toc.splice(16, 0, { id: "suboxone-deadlines", label: "Deadline considerations" });
}
---

<GuideLayout
  title={lawsuit.data.title}
  seoTitle={seoTitle}
  description={seoDescription}
  breadcrumbs={breadcrumbs}
  faqs={lawsuit.data.faqs}
  article={{ dateModified: lawsuit.data.lastUpdated }}
  speakableSelectors={["h1", "#overview", "#latest-update"]}
>
  <header class="max-w-3xl">
    <CaseStatusBadge status={lawsuit.data.status} />
    <h1 class="mt-4 text-4xl font-black leading-tight tracking-normal text-ink">{lawsuit.data.lawsuit}</h1>
    <p class="mt-4 text-lg leading-8 text-muted">{lawsuit.data.description}</p>
    <p class="mt-4 rounded-lg border border-line bg-panel p-3 text-sm leading-6 text-muted">
      This guide is for general information only. It does not provide legal advice, does not create an attorney-client relationship, and case status can change.
    </p>
    <div class="mt-5 flex flex-wrap gap-3 text-sm font-semibold text-muted">
      <span>{lawsuit.data.category}</span>
      <span>Primary injury: {lawsuit.data.primaryInjury}</span>
      <span>Updated {formatDate(lawsuit.data.lastUpdated)}</span>
    </div>
  </header>

  <div class="mt-8 grid gap-8 lg:grid-cols-[220px_1fr_300px]">
    <div class="hidden lg:block">
      <div class="sticky top-24">
        <TableOfContents items={toc} />
      </div>
    </div>
    <aside class="space-y-5 lg:order-3">
      {caseData && <LitigationDataPanel data={caseData} />}
      <QuickFactsCard
        facts={[
          { label: "Case type", value: lawsuit.data.caseType },
          { label: "Primary alleged injury", value: lawsuit.data.primaryInjury },
          { label: "Current status", value: lawsuit.data.status },
          { label: "Who may be affected", value: lawsuit.data.affected },
          { label: "Evidence commonly needed", value: lawsuit.data.evidence.join(", ") },
          { label: "Related state guides", value: `${stateGuides.length} launch states` }
        ]}
      />
      <CaseStatusSnapshot
        status={lawsuit.data.status}
        category={lawsuit.data.category}
        primaryInjury={lawsuit.data.primaryInjury}
        lastUpdated={lawsuit.data.lastUpdated}
        stateGuideCount={stateGuides.length}
      />
      <DisclaimerBox />
    </aside>
    <div class="prose-legal max-w-none lg:order-2">
      <Content />

      <section id="injuries">
        <h2>Injuries involved</h2>
        <ul>
          {lawsuit.data.injuries.map((injury) => <li>{injury}</li>)}
        </ul>
      </section>

      <section id="evidence">
        <h2>Evidence usually needed</h2>
        <ul>
          {lawsuit.data.evidence.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section id="timeline">
        <h2>Timeline</h2>
        <div class="space-y-3">
          {lawsuit.data.timeline.map((item) => (
            <div class="rounded-lg border border-line bg-panel p-4">
              <h3 class="mt-0">{item.label}</h3>
              <p class="mb-0">{item.detail}</p>
            </div>
          ))}
        </div>
      </section>

      <section id="settlement">
        <h2>Settlement status</h2>
        <p>{lawsuit.data.settlementStatus}</p>
      </section>

      <section id="deadlines">
        <h2>Deadline overview</h2>
        <p>Deadlines vary by state and may depend on diagnosis date, discovery date, exposure history, wrongful death issues, and other facts. A lawyer can evaluate how the relevant deadline rules may apply.</p>
      </section>

      <section id="states">
        <h2>State-by-state guide links</h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {stateGuides.map((guide) => (
            <a class="rounded-lg border border-line bg-white p-4 font-bold hover:border-accent/50" href={`/lawsuits/${guide.data.lawsuitSlug}/${guide.data.stateSlug}/`}>
              {guide.data.title}
            </a>
          ))}
        </div>
      </section>
    </div>
  </div>

  <FAQSection faqs={lawsuit.data.faqs} />
  <RelatedStateGuides guides={stateGuides.slice(0, 6)} title={`${lawsuit.data.lawsuit} State Guides`} />
  <RelatedLawsuits lawsuits={related} title={relatedTitle} />
  <SourceUpdateLog lastReviewed={lawsuit.data.lastReviewed} lastUpdated={lawsuit.data.lastUpdated} />
</GuideLayout>

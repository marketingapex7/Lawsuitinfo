---
import GuideLayout from "@layouts/GuideLayout.astro";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Advertising Disclosure", url: "/advertising-disclosure/" }
];
---

<GuideLayout
  title="Advertising Disclosure"
  description="Advertising disclosure for Lawsuit Status Guide, including how paid placements would be identified if used."
  breadcrumbs={breadcrumbs}
>
  <div class="prose-legal max-w-3xl">
    <h1>Advertising Disclosure</h1>
    <p>Lawsuit Status Guide is a public legal information site. The site does not currently display paid legal placements, paid rankings, or referral listings.</p>
    <p>If paid placements are introduced in the future, they should be clearly labeled and kept separate from editorial guide content. Paid placement would not mean an endorsement, lawyer ranking, or claim evaluation.</p>
    <p>Readers should independently evaluate any lawyer or legal service they choose to contact. This site does not provide legal advice, does not create an attorney-client relationship, and does not guarantee any legal outcome.</p>
  </div>
</GuideLayout>

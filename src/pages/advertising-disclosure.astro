---
import GuideLayout from "@layouts/GuideLayout.astro";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Advertising Disclosure", url: "/advertising-disclosure/" }
];
---

<GuideLayout
  title="Advertising Disclosure"
  description="Disclosure explaining how future advertising or sponsorships may be identified and kept separate from editorial content."
  breadcrumbs={breadcrumbs}
>
  <div class="prose-legal max-w-3xl">
    <h1>Advertising Disclosure</h1>
    <p>This site currently focuses on general legal information. Advertising, sponsorships, or paid placements may be added in the future and will be clearly disclosed if they appear.</p>
    <h2>What advertising would mean</h2>
    <p>Any future advertising or paid placement would not mean endorsement, ranking, recommendation, or a statement that an advertiser is the best lawyer for any person or claim.</p>
    <h2>Editorial independence</h2>
    <p>Advertisers would not control the editorial content of lawsuit guides. Informational content should remain neutral, cautious, and separate from advertising.</p>
    <h2>Evaluate lawyers independently</h2>
    <p>Users should independently evaluate any lawyer or law firm, ask questions about experience, fees, referrals, and case handling, and decide whether to contact a licensed attorney.</p>
  </div>
</GuideLayout>

---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import LawsuitCard from "@components/LawsuitCard.astro";
import CategoryCard from "@components/CategoryCard.astro";
import StateGrid from "@components/StateGrid.astro";
import { entrySlug } from "@lib/content";
import { formatDate, states } from "@lib/site";

const lawsuits = (await getCollection("lawsuits")).sort((a, b) => a.data.lawsuit.localeCompare(b.data.lawsuit));
const latestUpdated = lawsuits.map((item) => item.data.lastUpdated).sort().at(-1) ?? "2026-05-20";
---

<BaseLayout
  title="Plain-English Guides to Active Injury and Mass Tort Lawsuits"
  seoTitle="Mass Tort & Injury Lawsuit Guides"
  description="Track the status of major mass tort and injury lawsuits: alleged injuries, settlement posture, deadlines, evidence, and state-specific legal context."
  isHome={true}
>
  <section class="border-b border-line bg-[#eef7f8]">
    <div class="mx-auto max-w-6xl px-4 py-12 md:py-16">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-[0.12em] text-accent-dark">Mass tort and injury case-status guides</p>
        <h1 class="mt-3 text-4xl font-black leading-tight tracking-normal text-ink md:text-5xl">
          Plain-English Guides to Active Injury and Mass Tort Lawsuits
        </h1>
        <p class="mt-5 text-lg leading-8 text-muted">
          Track lawsuit status, alleged injuries, settlement posture, deadlines, evidence commonly reviewed, and state-specific legal context for major injury and mass tort claims.
        </p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a class="rounded-md bg-accent px-5 py-3 text-center text-sm font-bold text-white hover:bg-accent-dark" href="/lawsuits/">View Lawsuit Guides</a>
          <a class="rounded-md border border-line bg-white px-5 py-3 text-center text-sm font-bold text-ink hover:bg-panel" href="/states/">Browse by State</a>
        </div>
        <div class="mt-5 flex flex-wrap gap-3 text-sm font-bold text-accent-dark">
          <a href="/settlements/">Settlement tracker</a>
          <a href="/deadlines/">Deadline tracker</a>
          <a href="/mdl-statistics/">MDL statistics</a>
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-6xl space-y-12 px-4 py-10">
    <section class="rounded-lg border border-line bg-white p-5 shadow-sm">
      <div class="flex items-end justify-between gap-4">
        <div>
          <div class="mb-4 h-1 w-14 rounded-full bg-accent"></div>
          <h2 class="text-2xl font-bold text-ink">Featured Active Lawsuits</h2>
          <p class="mt-2 text-sm leading-6 text-muted">Neutral summaries for the five launch lawsuit guides.</p>
        </div>
        <a class="hidden text-sm font-bold text-accent-dark sm:inline" href="/lawsuits/">All guides</a>
      </div>
      <div class="mt-5 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {lawsuits.map((lawsuit) => <LawsuitCard lawsuit={lawsuit} />)}
      </div>
      <div class="mt-6 rounded-lg border border-line bg-[#f1f5f9] p-4">
        <h3 class="text-base font-bold text-ink">Launch State Pages</h3>
        <div class="mt-4 space-y-4">
          {lawsuits.map((lawsuit) => {
            const slug = entrySlug(lawsuit);
            return (
              <div>
                <a class="text-sm font-bold text-accent-dark" href={`/lawsuits/${slug}/`}>{lawsuit.data.lawsuit}</a>
                <div class="mt-2 flex flex-wrap gap-2">
                  {states.map((state) => (
                    <a class="rounded-md border border-line bg-white px-2.5 py-1.5 text-xs font-bold text-muted hover:border-accent/50 hover:text-ink" href={`/lawsuits/${slug}/${state.slug}/`}>
                      {state.name}
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <section class="rounded-lg border border-line bg-white p-5 shadow-sm">
      <div class="mb-4 h-1 w-14 rounded-full bg-accent"></div>
      <h2 class="text-2xl font-bold text-ink">Browse by Category</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        <CategoryCard title="Defective Drugs" description="Medication-focused claims involving alleged injuries after prescription or clinical use." href="/categories/defective-drugs/" />
        <CategoryCard title="Toxic Exposure" description="Claims involving alleged chemical, pesticide, PFAS, or environmental exposure injuries." href="/categories/toxic-exposure/" />
        <CategoryCard title="Product Liability" description="A broad view of product-related injury claims in the launch lawsuit library." href="/categories/product-liability/" />
      </div>
    </section>

    <section class="rounded-lg border border-line bg-white p-5 shadow-sm">
      <div class="mb-4 h-1 w-14 rounded-full bg-accent"></div>
      <h2 class="text-2xl font-bold text-ink">Track Case Data</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        <a class="rounded-lg border border-line bg-panel p-4 hover:border-accent/50" href="/settlements/">
          <h3 class="text-lg font-bold text-ink">Settlement Tracker</h3>
          <p class="mt-2 text-sm leading-6 text-muted">Public settlement posture, pending counts, and source links by case.</p>
        </a>
        <a class="rounded-lg border border-line bg-panel p-4 hover:border-accent/50" href="/deadlines/">
          <h3 class="text-lg font-bold text-ink">Deadline Tracker</h3>
          <p class="mt-2 text-sm leading-6 text-muted">Court dates, filing-window notes, and state deadline reminders.</p>
        </a>
        <a class="rounded-lg border border-line bg-panel p-4 hover:border-accent/50" href="/mdl-statistics/">
          <h3 class="text-lg font-bold text-ink">MDL Statistics</h3>
          <p class="mt-2 text-sm leading-6 text-muted">Pending-action counts, courts, judges, and JPML source links.</p>
        </a>
      </div>
    </section>

    <section class="rounded-lg border border-line bg-[#eef7f8] p-5">
      <div class="mb-4 h-1 w-14 rounded-full bg-accent"></div>
      <h2 class="text-2xl font-bold text-ink">Browse by State</h2>
      <p class="mt-2 text-sm leading-6 text-muted">Launch state pages include state deadline considerations, records to gather, and federal court context.</p>
      <div class="mt-5">
        <StateGrid />
      </div>
    </section>

    <section class="rounded-lg border border-line bg-white p-5 shadow-sm">
      <div class="mb-4 h-1 w-14 rounded-full bg-accent"></div>
      <h2 class="text-2xl font-bold text-ink">How These Guides Work</h2>
      <div class="mt-4 space-y-3 text-sm leading-6 text-muted">
        <p>Each lawsuit guide starts with a national overview, then links to state-specific context for the launch states.</p>
        <p>The pages explain alleged injuries, possible eligibility factors, common evidence, deadline considerations, and litigation status in cautious plain English.</p>
        <p>This site provides general legal information only and does not provide legal advice.</p>
      </div>
    </section>

    <section class="rounded-lg border border-accent/20 bg-[#eef7f8] p-5">
      <div class="mb-4 h-1 w-14 rounded-full bg-accent"></div>
      <h2 class="text-2xl font-bold text-ink">Latest Update and Editorial Trust</h2>
      <p class="mt-3 text-sm leading-6 text-muted">
        Launch content was last updated {formatDate(latestUpdated)}. Each guide includes review dates, cautious legal language, source/update notes, and links to editorial policy.
      </p>
      <div class="mt-4 flex flex-wrap gap-3 text-sm font-bold text-accent-dark">
        <a href="/editorial-policy/">Editorial Policy</a>
        <a href="/legal-disclaimer/">Legal Disclaimer</a>
      </div>
    </section>
  </div>
</BaseLayout>

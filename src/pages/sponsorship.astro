---
import GuideLayout from "@layouts/GuideLayout.astro";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Advertising Status", url: "/sponsorship/" }
];
---

<GuideLayout
  title="Advertising Status"
  description="Advertising and paid placements are not currently active on Injury Lawsuit Guide."
  breadcrumbs={breadcrumbs}
  noindex={true}
>
  <div class="prose-legal max-w-3xl">
    <h1>Advertising Status</h1>
    <p>Advertising and paid placements are not currently active on this site.</p>
    <p>If advertising is added in the future, it will be clearly disclosed and kept separate from editorial content.</p>
    <p><a href="/advertising-disclosure/">Read the advertising disclosure</a>.</p>
  </div>
</GuideLayout>

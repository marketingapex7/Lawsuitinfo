---
import GuideLayout from "@layouts/GuideLayout.astro";
import { site } from "@lib/site";

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Contact", url: "/contact/" }
];
---

<GuideLayout
  title="Contact"
  description="Contact Lawsuit Status Guide about editorial updates, corrections, or general site questions."
  breadcrumbs={breadcrumbs}
>
  <div class="grid gap-8 md:grid-cols-[1fr_320px]">
    <div class="prose-legal">
      <h1>Contact</h1>
      <p>For editorial updates, corrections, source suggestions, or general site inquiries, contact the site team by email.</p>
      <p><a class="font-bold text-accent-dark" href={`mailto:${site.email}`}>{site.email}</a></p>
      <p>Please do not send confidential legal, medical, or case documents through email unless you already have a direct attorney-client relationship with the recipient.</p>
    </div>
    <aside class="rounded-lg border border-line bg-panel p-5">
      <h2 class="text-xl font-bold text-ink">Before you email</h2>
      <p class="mt-3 text-sm leading-6 text-muted">This site cannot evaluate claims, provide legal advice, calculate deadlines, or match you with a lawyer.</p>
      <a class="mt-4 inline-flex rounded-md bg-accent px-4 py-2 text-sm font-bold text-white hover:bg-accent-dark" href="/legal-disclaimer/">Read legal disclaimer</a>
    </aside>
  </div>
</GuideLayout>

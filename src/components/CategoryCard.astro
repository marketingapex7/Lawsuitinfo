---
const { title, description, href } = Astro.props;
---

<a class="rounded-lg border border-line border-t-4 border-t-accent bg-white p-5 shadow-sm hover:border-accent/50" href={href}>
  <h3 class="text-lg font-bold text-ink">{title}</h3>
  <p class="mt-2 text-sm leading-6 text-muted">{description}</p>
</a>

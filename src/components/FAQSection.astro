---
const { faqs = [] } = Astro.props;
---

{faqs.length > 0 && (
  <section id="faq" class="mt-10 rounded-lg border border-line bg-[#f1f5f9] p-4">
    <h2 class="text-2xl font-bold tracking-normal text-ink">Frequently Asked Questions</h2>
    <div class="mt-4 grid gap-3">
      {faqs.map((faq) => (
        <details class="group rounded-lg border border-line bg-white p-4 shadow-sm">
          <summary class="cursor-pointer list-none text-base font-bold text-ink">
            {faq.question}
          </summary>
          <p class="mt-3 text-sm leading-6 text-muted">{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>
)}

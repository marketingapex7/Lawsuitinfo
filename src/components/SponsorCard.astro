---
const { status = "available", lawsuit, state, sponsor } = Astro.props;

const label = status === "sold" ? "Featured sponsor" : status === "reserved" ? "Sponsor slot reserved" : "Exclusive sponsor slot available";
const title = state ? `${state} Sponsor Slot ${status === "available" ? "Available" : status === "reserved" ? "Reserved" : "Filled"}` : label;
const availableCopy = state
  ? "Only one legal sponsor is featured for each lawsuit/state guide. Sponsorship provides exclusive placement on this page and related guide sections."
  : "National sponsor slot available for this lawsuit guide.";
---

<aside class="rounded-lg border border-line bg-white p-4 shadow-sm">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h2 class="text-lg font-bold text-ink">{title}</h2>
    <span class="rounded-full border border-gold/25 bg-[#fff8e8] px-3 py-1 text-xs font-bold uppercase tracking-[0.08em] text-gold">{status}</span>
  </div>
  {status === "sold" && sponsor?.name ? (
    <div class="mt-4 space-y-2 text-sm leading-6 text-muted">
      <p class="font-bold text-ink">{sponsor.name}</p>
      {sponsor.description && <p>{sponsor.description}</p>}
      {sponsor.phone && <p><a class="font-semibold text-accent-dark" href={`tel:${sponsor.phone}`}>{sponsor.phone}</a></p>}
      {sponsor.website && <p><a class="font-semibold text-accent-dark" href={sponsor.website}>Visit sponsor website</a></p>}
      <p class="text-xs">Paid sponsorship disclosure: placement does not control editorial content and does not imply endorsement.</p>
    </div>
  ) : (
    <div class="mt-4 space-y-3 text-sm leading-6 text-muted">
      <p>{availableCopy}</p>
      <a class="inline-flex rounded-md bg-accent px-4 py-2 text-sm font-bold text-white hover:bg-accent-dark" href="/sponsorship/">View sponsorship information</a>
    </div>
  )}
</aside>

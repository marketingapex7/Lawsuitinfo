---
const { items = [] } = Astro.props;
---

<nav class="rounded-lg border border-line bg-white p-4" aria-label="Page sections">
  <h2 class="text-sm font-bold uppercase tracking-[0.08em] text-muted">On this page</h2>
  <ol class="mt-3 space-y-2 text-sm font-semibold text-ink">
    {items.map((item) => (
      <li><a class="hover:text-accent-dark" href={`#${item.id}`}>{item.label}</a></li>
    ))}
  </ol>
</nav>

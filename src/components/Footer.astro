---
import { site } from "@lib/site";
---

<footer class="border-t border-line bg-panel">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 md:grid-cols-[1.3fr_1fr_1fr]">
    <div>
      <p class="text-base font-bold text-ink">{site.name}</p>
      <p class="mt-3 max-w-md text-sm leading-6 text-muted">
        Public legal information about active injury and mass tort lawsuits. This site is not a law firm and does not provide legal advice.
      </p>
    </div>
    <div>
      <p class="text-sm font-bold text-ink">Guides</p>
      <ul class="mt-3 space-y-2 text-sm text-muted">
        <li><a class="hover:text-ink" href="/lawsuits/">Lawsuit Guides</a></li>
        <li><a class="hover:text-ink" href="/categories/defective-drugs/">Defective Drugs</a></li>
        <li><a class="hover:text-ink" href="/categories/toxic-exposure/">Toxic Exposure</a></li>
        <li><a class="hover:text-ink" href="/categories/product-liability/">Product Liability</a></li>
      </ul>
    </div>
    <div>
      <p class="text-sm font-bold text-ink">Trust</p>
      <ul class="mt-3 space-y-2 text-sm text-muted">
        <li><a class="hover:text-ink" href="/editorial-policy/">About / Editorial Policy</a></li>
        <li><a class="hover:text-ink" href="/legal-disclaimer/">Legal Disclaimer</a></li>
        <li><a class="hover:text-ink" href="/contact/">Contact</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-line px-4 py-4 text-center text-xs text-muted">
    &copy; {new Date().getFullYear()} {site.name}. Informational content only.
  </div>
</footer>
